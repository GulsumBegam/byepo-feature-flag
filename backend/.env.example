# Your Neon (or any Postgres) connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Secret used to sign JWTs — use a long random string in real deployment
JWT_SECRET="replace-this-with-a-long-random-string"

# Static Super Admin credentials (per assignment: "static credentials, hardcoded or config-based")
SUPER_ADMIN_USERNAME="superadmin"
# This is a bcrypt HASH, not a plain password.
# Generate your own with: node -e "console.log(require('bcrypt').hashSync('yourPasswordHere', 10))"
SUPER_ADMIN_PASSWORD_HASH="$2b$10$replaceThisWithARealBcryptHash"

PORT=5000
